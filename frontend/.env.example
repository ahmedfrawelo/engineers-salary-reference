# ==== SSH/SCP Configuration (VPS) ====
# Copy this file to .env and fill in the real values.
# .env is git-ignored and must never be committed.

SSH_HOST=your-server-ip-here
SSH_PORT=22
SSH_USER=your-username-here
VPS_SSH_KEY=C:\Users\your-user\.ssh\engineers-salary-reference_vps
VPS_HOST_FINGERPRINT=SHA256:replace_with_server_host_key_fingerprint
SSH_REMOTE_DIR=/var/www/engineers-salary-reference-frontend
BUILD_DIR=dist/engineers-salary-reference

# Security notes:
# 1. Use SSH keys only. Do not store server passwords in repository files.
# 2. Keep the private key outside the repository whenever possible.
# 3. Verify and pin the VPS host fingerprint before deployment.
